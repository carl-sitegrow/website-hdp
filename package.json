{
  "name": "website-hdp",
  "type": "module",
  "version": "1.0.0",
  "description": "Sitegrow Skeleton — gabarit Astro bilingue (FR/EN) réutilisable, propulsé par Astro v7 + Tailwind v4.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "astro dev --port 4325 --host",
    "start": "astro dev --port 4325 --host",
    "validate": "tsx scripts/validate-site-config.ts",
    "build": "npm run validate && astro build && node scripts/fix-vercel-runtime.js",
    "check": "astro check",
    "check:all": "astro check && prettier --check . && eslint .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:links": "linkinator dist/ --recurse --silent",
    "preview": "astro preview",
    "astro": "astro",
    "vercel-build": "npm run build",
    "optimize-logo": "node scripts/optimize-logo.js",
    "generate-og": "node scripts/generate-og-default.js",
    "generate-placeholders": "node scripts/generate-placeholders.js",
    "setup": "node scripts/setup-other-machine.js"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/vercel": "^11.0.2",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "astro": "^7.0.6",
    "rehype-slug": "^6.0.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.7.0",
    "linkinator": "^7.6.1",
    "prettier": "^3.9.4",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "zod": "^3.25.76"
  }
}
