---
import { homeContent } from '@/data/home';

const { hero } = homeContent;
---
<section class="relative overflow-hidden px-5 pb-20 pt-16 sm:px-8 sm:pb-24 sm:pt-20 lg:px-10">
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-[600px]"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(138,92,246,0.05) 0%, transparent 70%);"
  ></div>

  <div class="relative mx-auto max-w-5xl text-center">
    {hero.eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-[0.1em] text-brand">{hero.eyebrow}</p>
    )}
    <h1 class="mt-4 text-4xl font-bold leading-[1.15] tracking-[-0.03em] text-ink sm:text-6xl lg:text-[72px] lg:leading-[1.15]">
      {hero.title.map((line) => (
        <span class="block">{line}</span>
      ))}
    </h1>

    <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-muted sm:text-[22px] sm:leading-[33px]">
      {hero.subtitle}
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={hero.primaryCta.href}
        class="inline-flex w-full items-center justify-center rounded-md bg-brand px-7 py-3.5 text-base font-semibold text-white shadow-[0_4px_7px_rgba(0,0,0,0.1)] transition-colors hover:bg-brand-hover sm:w-auto"
      >
        {hero.primaryCta.label}
      </a>
      <a
        href={hero.secondaryCta.href}
        class="inline-flex w-full items-center justify-center rounded-md border border-black/[0.08] bg-white px-7 py-3.5 text-base font-semibold text-ink transition-colors hover:border-black/15 hover:bg-gray-50 sm:w-auto"
      >
        {hero.secondaryCta.label}
      </a>
    </div>
  </div>
</section>
