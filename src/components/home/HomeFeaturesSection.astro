---
import { homeContent } from '@/data/home';

const { features } = homeContent;
---
<section class="border-t border-black/[0.08] bg-surface px-5 py-20 sm:px-8 sm:py-28 lg:px-10">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.1em] text-brand">{features.eyebrow}</p>
      <h2 class="mt-4 text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl">{features.title}</h2>
      {features.subtitle && (
        <p class="mt-6 text-lg leading-relaxed text-muted">{features.subtitle}</p>
      )}
    </div>

    <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
      {features.items.map((item) => (
        <article class="rounded-lg border border-black/[0.08] bg-white p-8 shadow-[0_4px_24px_-4px_rgba(0,0,0,0.05)]">
          <h3 class="text-xl font-bold text-ink">{item.title}</h3>
          <p class="mt-4 text-base leading-relaxed text-muted">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
