---
import { siteConfig } from '@/config/site';
import SiteLogo from '@components/home/SiteLogo.astro';

const { footer } = siteConfig;
const year = new Date().getFullYear();

const socialLinks = [
  { label: 'Instagram', href: siteConfig.social.instagram },
  { label: 'Facebook', href: siteConfig.social.facebook },
  { label: 'LinkedIn', href: siteConfig.social.linkedin },
  { label: 'YouTube', href: siteConfig.social.youtube },
  { label: 'X', href: siteConfig.social.x },
].filter((l) => l.href);
---
<footer class="border-t border-black/[0.08] bg-white px-5 pb-10 pt-20 sm:px-8 sm:pt-24 lg:px-10">
  <div class="mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <SiteLogo height={36} />
        <p class="mt-6 max-w-xs text-[15px] leading-6 text-muted">{footer.tagline}</p>
      </div>

      {footer.columns.map((column) => (
        <div>
          <p class="text-[15px] font-semibold uppercase tracking-[0.05em] text-ink">{column.title}</p>
          <ul class="mt-6 flex flex-col gap-4">
            {column.links.map((link) => (
              <li>
                <a href={link.href} class="text-[15px] text-muted transition-colors hover:text-ink">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <p class="text-[15px] font-semibold uppercase tracking-[0.05em] text-ink">Contact</p>
        <ul class="mt-6 flex flex-col gap-3">
          {siteConfig.contactEmail && (
            <li>
              <a href={`mailto:${siteConfig.contactEmail}`} class="text-[15px] text-muted transition-colors hover:text-ink">
                {siteConfig.contactEmail}
              </a>
            </li>
          )}
          {siteConfig.phone && (
            <li>
              <span class="text-[15px] text-muted">{siteConfig.phone}</span>
            </li>
          )}
          {siteConfig.address && (
            <li>
              <span class="text-[15px] text-muted">{siteConfig.address}</span>
            </li>
          )}
        </ul>
        {socialLinks.length > 0 && (
          <>
            <p class="mt-6 text-[15px] font-semibold uppercase tracking-[0.05em] text-ink">Suivez-nous</p>
            <ul class="mt-4 flex flex-col gap-3">
              {socialLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[15px] text-muted transition-colors hover:text-ink"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )}
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center gap-4 border-t border-black/[0.08] pt-10 sm:flex-row sm:justify-between">
      <p class="text-sm text-muted">
        &copy; {year} {siteConfig.siteName}. Tous droits réservés.
      </p>
      <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2">
        {footer.legal.links.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-muted transition-colors hover:text-ink">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
