---
import type { Post } from '@/data/posts';
import { getPostHref, postUi } from '@/data/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const href = getPostHref(post);
const Tag = post.published ? 'a' : 'article';
---
<Tag
  {...(post.published ? { href } : {})}
  class:list={[
    'flex flex-col rounded-lg border border-black/[0.08] bg-white p-6 shadow-[0_4px_24px_-4px_rgba(0,0,0,0.05)] sm:p-8',
    post.published
      ? 'group transition-shadow hover:shadow-[0_8px_32px_-4px_rgba(0,0,0,0.08)]'
      : 'opacity-75',
  ]}
>
  <div class="flex flex-wrap items-center gap-3">
    {post.category && (
      <span class="rounded-full bg-brand-light px-3 py-1 text-[13px] font-semibold text-brand">
        {post.category}
      </span>
    )}
    <span class="text-sm font-medium text-muted">{post.date}</span>
    {!post.published && (
      <span class="rounded-full bg-surface px-3 py-1 text-xs font-semibold uppercase tracking-wide text-muted">
        {postUi.comingSoon}
      </span>
    )}
  </div>
  <h2
    class:list={[
      'mt-4 text-xl font-bold tracking-tight text-ink sm:text-2xl',
      post.published && 'transition-colors group-hover:text-brand',
    ]}
  >
    {post.title}
  </h2>
  <p class="mt-3 flex-1 text-base leading-relaxed text-muted">{post.summary}</p>
  {post.published && (
    <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand">
      {postUi.readArticle}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </span>
  )}
</Tag>
