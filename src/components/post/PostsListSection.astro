---
import PostCard from './PostCard.astro';
import { posts, postUi } from '@/data/posts';
---
<section class="px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
  <div class="mx-auto max-w-3xl">
    <div class="text-center sm:text-left">
      <p class="text-sm font-semibold uppercase tracking-[0.1em] text-brand">{postUi.listEyebrow}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl">
        {postUi.listTitle}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-muted sm:mx-0">
        {postUi.listSubtitle}
      </p>
    </div>

    {posts.length > 0 ? (
      <ul class="mt-12 flex flex-col gap-6">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    ) : (
      <p class="mt-12 rounded-lg border border-dashed border-black/[0.15] bg-surface p-8 text-center text-base text-muted">
        Aucun article pour le moment. Ajoutez-en dans <code class="rounded bg-white px-1.5 py-0.5 text-ink">src/data/posts.ts</code>.
      </p>
    )}
  </div>
</section>
