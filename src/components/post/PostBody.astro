---
import type { Post } from '@/data/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
---
<section class="px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
  <div class="mx-auto max-w-3xl">
    <article class="space-y-10">
      {post.sections.map((section) => (
        <div>
          {section.heading && (
            <h2 class="text-2xl font-bold tracking-tight text-ink sm:text-3xl">{section.heading}</h2>
          )}
          <div class:list={[section.heading ? 'mt-4' : '']}>
            {section.paragraphs.map((paragraph) => (
              <p class="text-lg leading-relaxed text-muted">{paragraph}</p>
            ))}
            {section.bullets && (
              <ul class="mt-4 space-y-3">
                {section.bullets.map((item) => (
                  <li class="flex gap-3 text-lg leading-relaxed text-muted">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </article>

    {post.author && (
      <footer class="mt-16 flex items-center gap-4 border-t border-black/[0.08] pt-10">
        <picture>
          <source srcset={`${post.author.image}.avif`} type="image/avif" />
          <source srcset={`${post.author.image}.webp`} type="image/webp" />
          <img
            src={`${post.author.image}.webp`}
            alt={post.author.name}
            class="h-14 w-14 rounded-full object-cover"
            loading="lazy"
            width="56"
            height="56"
          />
        </picture>
        <div>
          <p class="font-bold text-ink">{post.author.name}</p>
          <p class="text-sm text-muted">{post.author.role}</p>
        </div>
      </footer>
    )}
  </div>
</section>
