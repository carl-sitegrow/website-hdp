---
import type { Post } from '@/data/posts';

interface Props {
  author: Post['author'];
}
const { author } = Astro.props;
---
<div class="flex flex-col items-center gap-8 rounded-2xl bg-brand-light p-10 sm:flex-row sm:items-start">
  <picture>
    <source srcset={`${author.image}.avif`} type="image/avif" />
    <source srcset={`${author.image}.webp`} type="image/webp" />
    <img
      src={`${author.image}.webp`}
      alt={author.name}
      width="100"
      height="100"
      class="size-[100px] shrink-0 rounded-full object-cover"
      loading="lazy"
    />
  </picture>
  <div>
    <p class="font-serif text-2xl font-semibold text-ink">{author.name}</p>
    {author.bio && <p class="mt-3 text-base leading-relaxed text-muted">{author.bio}</p>}
  </div>
</div>
