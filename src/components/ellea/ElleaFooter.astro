---
import { siteConfig } from '@/config/site';

const { footer } = siteConfig;
---
<footer class="bg-bg px-6 pb-10 pt-24 lg:px-[120px]">
  <div class="mx-auto max-w-[1200px]">
    <div class="flex flex-col gap-16 lg:flex-row lg:justify-between">
      <div class="max-w-[300px]">
        <a href="/" class="font-serif text-[32px] font-bold text-brand">Ellea</a>
        <p class="mt-6 text-[15px] leading-relaxed text-muted">{footer.tagline}</p>
      </div>

      <div class="flex gap-16 lg:gap-[100px]">
        {footer.columns.map((column) => (
          <div>
            <p class="text-sm font-bold uppercase text-ink">{column.title}</p>
            <ul class="mt-5 flex flex-col gap-5">
              {column.links.map((link) => (
                <li>
                  <a href={link.href} class="text-[15px] text-muted transition-colors hover:text-ink">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-20 border-t border-border pt-6 text-center">
      <p class="text-sm text-muted/60">© 2024 Ellea Blog Santé. Tous droits réservés.</p>
      {footer.legal.links.length > 0 && (
        <ul class="mt-3 flex justify-center gap-6">
          {footer.legal.links.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-muted transition-colors hover:text-ink">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</footer>
