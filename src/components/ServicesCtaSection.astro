---
import { siteConfig } from '@/config/site';
---
<section class="relative py-16 sm:py-24 lg:py-32 overflow-hidden">
  <div
    class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full"
    aria-hidden="true"
    style="background: radial-gradient(circle, rgba(138,92,246,0.08) 0%, rgba(138,92,246,0) 60%);"
  ></div>

  <div class="relative max-w-[640px] mx-auto px-5 sm:px-10 text-center flex flex-col items-center gap-4 sm:gap-6">
    <h2 class="text-3xl sm:text-4xl lg:text-[48px] font-bold tracking-tight leading-tight text-ink">
      Parlons de votre projet
    </h2>

    <p class="text-muted text-lg lg:text-xl leading-relaxed">
      Une question ou une demande de soumission ? Écrivez-nous, on vous répond rapidement.
    </p>

    <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 pt-4 justify-center">
      <a href="/contact/" class="rounded-md bg-brand px-7 py-3.5 text-sm font-semibold text-white shadow-[0_4px_7px_rgba(0,0,0,0.1)] transition-colors hover:bg-brand-hover text-center">
        {siteConfig.navCta.label}
      </a>
    </div>
  </div>
</section>
