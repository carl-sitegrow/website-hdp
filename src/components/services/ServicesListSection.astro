---
import { services } from '@/data/services';
import ResponsiveImage from '@components/ResponsiveImage.astro';
---
<section class="max-w-[1440px] mx-auto px-5 sm:px-10 lg:px-20 py-12 sm:py-20">
  <div class="flex flex-col gap-16 sm:gap-20 lg:gap-40">
    {services.map((service) => (
      <div class:list={['grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center', service.reverse && 'lg:[direction:rtl] lg:[&>*]:[direction:ltr]']}>
        <div class="rounded-xl border border-black/[0.08] overflow-hidden bg-surface">
          {service.image && (
            <ResponsiveImage
              src={service.image}
              alt={service.imageAlt ?? service.title}
              width={800}
              height={600}
              sizes="(min-width: 1024px) 640px, 100vw"
              class="w-full h-auto aspect-[4/3] object-cover"
            />
          )}
        </div>

        <div class="flex flex-col gap-4">
          <h2 class="text-3xl lg:text-[40px] font-extrabold tracking-tight leading-tight text-ink">
            {service.title}
          </h2>

          <p class="text-muted text-base lg:text-lg leading-relaxed">
            {service.description}
          </p>

          {service.features && service.features.length > 0 && (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 sm:gap-y-4 pt-4">
              {service.features.map((feat) => (
                <div class="flex items-center gap-3">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand shrink-0" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  <span class="text-sm lg:text-base font-medium text-ink">{feat}</span>
                </div>
              ))}
            </div>
          )}

          {service.cta && (
            <a href={service.cta.href} class="inline-flex w-fit mt-4 rounded-md bg-brand px-7 py-3.5 text-sm font-semibold text-white transition-colors hover:bg-brand-hover">
              {service.cta.label}
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
