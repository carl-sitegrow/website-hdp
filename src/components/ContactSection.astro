---
import { contactContent } from '@/data/contact';
import { siteConfig } from '@/config/site';
import { PUBLIC_FORMSPREE_ID } from 'astro:env/client';

const { title, subtitle, blocks, topics, form } = contactContent;
const formspreeId = PUBLIC_FORMSPREE_ID?.trim();
const endpoint = formspreeId ? `https://formspree.io/f/${formspreeId}` : null;
---

<section class="px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
  <div class="mx-auto max-w-6xl">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.1em] text-brand">{title}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl">{title}</h1>
      <p class="mt-5 text-lg leading-relaxed text-muted">{subtitle}</p>
    </div>

    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {blocks.map((block) => (
        <article class="rounded-lg border border-black/[0.08] bg-white p-6 shadow-[0_4px_24px_-4px_rgba(0,0,0,0.05)]">
          <h2 class="text-lg font-bold text-ink">{block.title}</h2>
          <p class="mt-3 text-base leading-relaxed text-muted">{block.text}</p>
        </article>
      ))}
    </div>

    <div class="mt-16 max-w-2xl">
      <h2 class="text-2xl font-bold text-ink">{form.title}</h2>

      {endpoint ? (
        <form
          id="contact-form"
          class="mt-8 flex flex-col gap-5"
          action={endpoint}
          method="POST"
          data-endpoint={endpoint}
          data-submitting={form.submitting}
          data-submit={form.submit}
          data-success-title={form.successTitle}
          data-success-message={form.successMessage}
          data-success-reset={form.successReset}
          data-error-generic={form.errorGeneric}
          data-error-network={form.errorNetwork}
          novalidate
        >
          <p
            id="contact-status"
            role="status"
            aria-live="polite"
            class="hidden rounded-md border px-4 py-3 text-sm"
          >
          </p>

          <input type="hidden" name="_subject" value={`Nouveau message : ${siteConfig.siteName}`} />
          {/* Formspree : désactive le captcha côté service (on s'en remet à son filtre anti-spam intégré) */}
          <input type="hidden" name="_captcha" value="false" />

          <div>
            <label class="mb-2 block text-sm font-semibold text-ink" for="contact-name">{form.name}</label>
            <input
              id="contact-name"
              name="name"
              type="text"
              autocomplete="name"
              required
              class="contact-field w-full rounded-md border border-black/[0.08] px-4 py-3 text-base text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold text-ink" for="contact-email">{form.email}</label>
            <input
              id="contact-email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class="contact-field w-full rounded-md border border-black/[0.08] px-4 py-3 text-base text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold text-ink" for="contact-topic">{form.topic}</label>
            <select
              id="contact-topic"
              name="topic"
              class="contact-field w-full rounded-md border border-black/[0.08] bg-white px-4 py-3 text-base text-ink focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
            >
              {topics.map((topic) => (
                <option value={topic.value}>{topic.label}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold text-ink" for="contact-message">{form.message}</label>
            <textarea
              id="contact-message"
              name="message"
              rows="5"
              required
              placeholder={form.placeholder}
              class="contact-field w-full resize-y rounded-md border border-black/[0.08] px-4 py-3 text-base text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
            ></textarea>
          </div>
          <button
            type="submit"
            id="contact-submit"
            class="inline-flex items-center justify-center rounded-md bg-brand px-6 py-3.5 text-base font-semibold text-white shadow-[0_4px_7px_rgba(0,0,0,0.1)] transition-colors hover:bg-brand-hover disabled:cursor-not-allowed disabled:opacity-60"
          >
            {form.submit}
          </button>
        </form>
      ) : (
        <div class="mt-8 rounded-lg border border-dashed border-brand/40 bg-brand-light p-6">
          <p class="text-base font-semibold text-ink">{form.notConfiguredTitle}</p>
          <p class="mt-2 text-sm leading-relaxed text-muted">{form.notConfiguredMessage}</p>
          <a
            href={`mailto:${siteConfig.contactEmail}`}
            class="mt-4 inline-flex items-center justify-center rounded-md bg-brand px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-brand-hover"
          >
            {form.fallbackCta}
          </a>
        </div>
      )}
    </div>
  </div>
</section>

<script>
  function initContactForm() {
    const formEl = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!formEl || formEl.dataset.formInit === 'true') return;
    const form: HTMLFormElement = formEl;
    form.dataset.formInit = 'true';

    const endpointValue = form.dataset.endpoint;
    if (!endpointValue) return;
    const endpoint: string = endpointValue;

    const statusEl = document.getElementById('contact-status') as HTMLElement;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;

    const labels = {
      submitting: form.dataset.submitting || 'Envoi…',
      submit: form.dataset.submit || 'Envoyer',
      successTitle: form.dataset.successTitle || 'Message envoyé',
      successMessage: form.dataset.successMessage || 'Merci !',
      successReset: form.dataset.successReset || 'Envoyer un autre message',
      errorGeneric: form.dataset.errorGeneric || 'Une erreur est survenue.',
      errorNetwork: form.dataset.errorNetwork || 'Connexion impossible.',
    };

    type FieldErrors = Record<string, string>;

    function setStatus(kind: 'error' | 'success' | 'idle', message: string) {
      statusEl.textContent = message;
      statusEl.classList.remove('hidden');
      if (kind === 'error') {
        statusEl.className =
          'rounded-md border border-red-200 bg-red-50 text-red-700 px-4 py-3 text-sm';
      } else if (kind === 'success') {
        statusEl.className =
          'rounded-md border border-green-200 bg-green-50 text-green-700 px-4 py-3 text-sm';
      } else {
        statusEl.className = 'hidden rounded-md border px-4 py-3 text-sm';
      }
    }

    function clearFieldErrors() {
      form.querySelectorAll<HTMLElement>('.contact-field').forEach((field) => {
        field.removeAttribute('aria-invalid');
        const next = field.parentElement?.querySelector('[data-field-error]');
        if (next) next.remove();
      });
    }

    function showFieldErrors(errors: FieldErrors) {
      Object.entries(errors).forEach(([name, msg]) => {
        const field = form.querySelector<HTMLElement>(`[name="${name}"]`);
        if (!field) return;
        field.setAttribute('aria-invalid', 'true');
        const errEl = document.createElement('p');
        errEl.className = 'mt-1.5 text-sm text-red-600';
        errEl.dataset.fieldError = 'true';
        errEl.textContent = msg;
        field.parentElement?.appendChild(errEl);
      });
    }

    async function handleSubmit(event: SubmitEvent) {
      event.preventDefault();
      clearFieldErrors();

      submitBtn.disabled = true;
      submitBtn.textContent = labels.submitting;
      setStatus('idle', '');

      const data = new FormData(form);

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          setStatus(
            'success',
            `${labels.successTitle} ${labels.successMessage}`,
          );
          const formWrapper = form;
          formWrapper.style.display = 'none';

          const resetBtn = document.createElement('button');
          resetBtn.type = 'button';
          resetBtn.className =
            'mt-4 inline-flex items-center justify-center rounded-md border border-black/[0.08] bg-white px-5 py-2.5 text-sm font-semibold text-ink transition-colors hover:bg-gray-50';
          resetBtn.textContent = labels.successReset;
          resetBtn.onclick = () => {
            formWrapper.reset();
            formWrapper.style.display = '';
            statusEl.classList.add('hidden');
            resetBtn.remove();
            submitBtn.disabled = false;
            submitBtn.textContent = labels.submit;
          };
          statusEl.parentElement?.appendChild(resetBtn);
          return;
        }

        // Validation côté serveur
        let errors: FieldErrors = {};
        try {
          const body = await res.json();
          if (body?.errors && Array.isArray(body.errors)) {
            errors = Object.fromEntries(
              body.errors.map((e: { field?: string; message?: string }) => [
                e.field,
                e.message || 'Champ invalide.',
              ]),
            );
          }
        } catch {
          // Réponse non-JSON (ex. 5xx HTML) — erreur générique
        }

        if (Object.keys(errors).length > 0) {
          showFieldErrors(errors);
          setStatus('error', labels.errorGeneric);
        } else {
          setStatus('error', labels.errorGeneric);
        }
      } catch {
        setStatus('error', labels.errorNetwork);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = labels.submit;
      }
    }

    form.addEventListener('submit', handleSubmit);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }
  document.addEventListener('astro:page-load', initContactForm);
</script>
