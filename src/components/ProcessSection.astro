---
import { processSteps } from '@/data/services';
---
<section class="py-16 sm:py-20 lg:py-28">
  <div class="max-w-[1440px] mx-auto px-5 sm:px-10 lg:px-20">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight text-center mb-10 sm:mb-16 text-ink">
      Notre processus
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {processSteps.map((step) => (
        <div class="bg-white border border-black/[0.08] rounded-xl p-8 relative overflow-hidden">
          <span class="absolute top-4 right-6 text-[80px] font-black text-black/[0.04] leading-none select-none">{step.number}</span>
          <div class="relative flex flex-col gap-4">
            <h3 class="text-2xl lg:text-[28px] font-extrabold tracking-tight text-ink">{step.title}</h3>
            <p class="text-muted text-sm lg:text-base leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
