---
import PageLayout from '@layouts/PageLayout.astro';
import JsonLd from '@components/JsonLd.astro';
import ServicesListSection from '@components/services/ServicesListSection.astro';
import ProcessSection from '@components/ProcessSection.astro';
import ServicesCtaSection from '@components/ServicesCtaSection.astro';
import { servicesContent, services } from '@/data/services';
import { breadcrumbTrails } from '@/lib/breadcrumb';
import { buildServicesGraph, buildFaqSchema } from '@/lib/schema';
import { formatTitle } from '@/lib/seo';

const origin = Astro.site ?? new URL(Astro.url.origin);
const servicesGraph = buildServicesGraph(services, origin);
const faqSchema = servicesContent.faq.length > 0 ? buildFaqSchema(servicesContent.faq) : null;
---
<PageLayout
  title={formatTitle(servicesContent.title)}
  description={servicesContent.metaDescription}
  breadcrumbs={breadcrumbTrails.services('fr')}
>
  <JsonLd schema={servicesGraph} />
  {faqSchema && <JsonLd schema={faqSchema} />}
  <main>
    <section class="px-5 pb-12 pt-16 sm:px-8 sm:pb-16 sm:pt-20 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl lg:text-6xl">
          {servicesContent.title}
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-muted">{servicesContent.intro}</p>
      </div>
    </section>

    <ServicesListSection />
    <ProcessSection />
    <ServicesCtaSection />
  </main>
</PageLayout>
