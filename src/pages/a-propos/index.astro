---
import PageLayout from '@layouts/PageLayout.astro';
import { siteConfig } from '@/config/site';
import { aboutContent } from '@/data/about';
import { breadcrumbTrails } from '@/lib/breadcrumb';

const { title, metaDescription, intro, values, team, cta } = aboutContent;
---
<PageLayout
  title={`${title} | ${siteConfig.siteName}`}
  description={metaDescription}
  breadcrumbs={breadcrumbTrails.about('fr')}
>
  <main>
    <section class="px-5 pb-12 pt-16 sm:px-8 sm:pb-16 sm:pt-20 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl lg:text-6xl">{title}</h1>
        {intro.map((paragraph) => (
          <p class="mt-6 text-lg leading-relaxed text-muted">{paragraph}</p>
        ))}
      </div>
    </section>

    <section class="border-y border-black/[0.08] bg-surface px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">{values.title}</h2>
        <div class="mt-10 grid grid-cols-1 gap-8 sm:grid-cols-3">
          {values.items.map((item) => (
            <article class="rounded-lg border border-black/[0.08] bg-white p-6 shadow-[0_4px_24px_-4px_rgba(0,0,0,0.05)]">
              <h3 class="text-lg font-bold text-ink">{item.title}</h3>
              <p class="mt-3 text-base leading-relaxed text-muted">{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">{team.title}</h2>
        <div class="mt-10 grid grid-cols-1 gap-10 sm:grid-cols-2">
          {team.items.map((member) => (
            <article class="rounded-lg border border-black/[0.08] bg-white p-8 text-center shadow-[0_4px_24px_-4px_rgba(0,0,0,0.05)]">
              {member.image && (
                <div class="mx-auto inline-block rounded-full border border-black/[0.08] p-2">
                  <picture>
                    <source srcset={`${member.image}.avif`} type="image/avif" />
                    <source srcset={`${member.image}.webp`} type="image/webp" />
                    <img
                      src={`${member.image}.webp`}
                      alt={member.name}
                      class="h-32 w-32 rounded-full object-cover"
                      loading="lazy"
                      width="128"
                      height="128"
                    />
                  </picture>
                </div>
              )}
              <h3 class="mt-6 text-2xl font-bold text-ink">{member.name}</h3>
              <p class="mt-1 text-sm font-semibold uppercase tracking-[0.05em] text-brand">{member.role}</p>
              <p class="mt-4 text-left text-lg leading-relaxed text-muted">{member.bio}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-black/[0.08] bg-surface px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-lg leading-relaxed text-muted">{cta.text}</p>
        <a
          href={cta.button.href}
          class="mt-8 inline-flex items-center justify-center rounded-md bg-brand px-7 py-3.5 text-base font-semibold text-white shadow-[0_4px_7px_rgba(0,0,0,0.1)] transition-colors hover:bg-brand-hover"
        >
          {cta.button.label}
        </a>
      </div>
    </section>
  </main>
</PageLayout>
