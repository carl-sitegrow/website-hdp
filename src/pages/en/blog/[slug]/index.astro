---
// EN mirror of /blog/[slug]/ — renders the same PostLayout for now (no EN translations yet).
// Posts are FR-only in the data model; this route exists to keep URL parity with /blog/[slug]/
// and to avoid breaking hreflang EN references. Marked noindex until real EN content lands.
import PostLayout from '@layouts/PostLayout.astro';
import { getPostBySlug, getPublishedPosts } from '@/data/posts';

export function getStaticPaths() {
  return getPublishedPosts().map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = slug ? getPostBySlug(slug) : undefined;

if (!post) {
  return Astro.redirect('/404/');
}
---
<PostLayout post={post} />
