---
import PageLayout from '@layouts/PageLayout.astro';
import ServicesListSection from '@components/services/ServicesListSection.astro';
import ProcessSection from '@components/ProcessSection.astro';
import ServicesCtaSection from '@components/ServicesCtaSection.astro';
import { siteConfig } from '@/config/site';
import { servicesContent } from '@/data/services';
import { breadcrumbTrails } from '@/lib/breadcrumb';
---
<PageLayout
  lang="en-CA"
  title={`${servicesContent.title} | ${siteConfig.siteName}`}
  description={servicesContent.metaDescription}
  breadcrumbs={breadcrumbTrails.services('en')}
>
  <main>
    <section class="px-5 pb-12 pt-16 sm:px-8 sm:pb-16 sm:pt-20 lg:px-10">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl lg:text-6xl">
          {servicesContent.title}
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-muted">{servicesContent.intro}</p>
      </div>
    </section>

    <ServicesListSection />
    <ProcessSection />
    <ServicesCtaSection />
  </main>
</PageLayout>
