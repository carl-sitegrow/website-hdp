---
import PageLayout from '@layouts/PageLayout.astro';
import { breadcrumbTrails, frPagesList } from '@/lib/breadcrumb';
import { siteConfig } from '@/config/site';

const mainLinks = frPagesList.filter((l) => l.section === 'main');
const legalLinks = frPagesList.filter((l) => l.section === 'legal');
---
<PageLayout
  title={`Plan du site | ${siteConfig.siteName}`}
  description="Plan du site — retrouvez toutes les pages en un coup d'œil."
  breadcrumbs={breadcrumbTrails.plan('fr')}
>
  <main class="px-5 py-16 sm:px-8 sm:py-20 lg:px-10">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-4xl font-bold tracking-[-0.02em] text-ink sm:text-5xl">Plan du site</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Toutes les pages de {siteConfig.siteName} regroupées sur une seule page.
      </p>

      <nav aria-label="Plan du site" class="mt-12">
        <h2 class="text-sm font-semibold uppercase tracking-[0.1em] text-brand">Pages principales</h2>
        <ul class="mt-6 flex flex-col gap-3">
          {mainLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="inline-flex items-center gap-2 text-lg font-medium text-ink transition-colors hover:text-brand"
              >
                <span aria-hidden="true">→</span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <h2 class="mt-12 text-sm font-semibold uppercase tracking-[0.1em] text-brand">Mentions légales</h2>
        <ul class="mt-6 flex flex-col gap-3">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="inline-flex items-center gap-2 text-base text-muted transition-colors hover:text-brand"
              >
                <span aria-hidden="true">→</span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </main>
</PageLayout>
