---
import PageLayout from '@layouts/PageLayout.astro';
import ResponsiveImage from '@components/ResponsiveImage.astro';
import ThemePills from '@components/ellea/ThemePills.astro';
import ArticleCard from '@components/ellea/ArticleCard.astro';
import Pagination from '@components/ellea/Pagination.astro';
import { siteConfig } from '@/config/site';
import { blogFilterThemes } from '@/data/themes';
import { getPublishedPosts, postUi, POSTS_PER_PAGE } from '@/data/posts';
import { breadcrumbTrails } from '@/lib/breadcrumb';

const allPosts = getPublishedPosts();
const totalPages = Math.max(1, Math.ceil(allPosts.length / POSTS_PER_PAGE));
const pagePosts = allPosts.slice(0, POSTS_PER_PAGE);
const activeCategory = Astro.url.searchParams.get('categorie') ?? '';
---
<PageLayout
  title={`${postUi.listTitle} | ${siteConfig.siteName}`}
  description={postUi.listSubtitle}
  breadcrumbs={breadcrumbTrails.blog('fr')}
  showBreadcrumb={false}
>
  <main>
    <section class="px-6 py-20 text-center lg:px-[120px]">
      <h1 class="font-serif text-5xl font-bold text-ink md:text-[56px]">{postUi.listTitle}</h1>
      <p class="mx-auto mt-5 max-w-[600px] text-xl leading-relaxed text-muted">{postUi.listSubtitle}</p>
    </section>

    <section class="border-y border-border px-6 py-10 lg:px-[120px]">
      <ThemePills themes={blogFilterThemes} activeSlug={activeCategory} showAll baseHref="/blog/" />
    </section>

    <section class="px-6 py-16 lg:px-[120px]" id="blog-grid" data-active-category={activeCategory}>
      <div class="mx-auto max-w-[1200px]">
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3" id="blog-posts">
          {pagePosts.map((post) => (
            <div data-category={post.categorySlug} class="blog-post-item">
              <ArticleCard post={post} variant="compact" />
            </div>
          ))}
        </div>
        <Pagination currentPage={1} totalPages={totalPages} />
      </div>
    </section>
  </main>
</PageLayout>

<script>
  function initBlogFilter() {
    const section = document.getElementById('blog-grid');
    if (!section) return;
    const active = section.dataset.activeCategory ?? '';
    if (!active) return;
    document.querySelectorAll<HTMLElement>('.blog-post-item').forEach((item) => {
      const cat = item.dataset.category ?? '';
      item.style.display = cat === active ? '' : 'none';
    });
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', initBlogFilter);
  else initBlogFilter();
  document.addEventListener('astro:page-load', initBlogFilter);
</script>
