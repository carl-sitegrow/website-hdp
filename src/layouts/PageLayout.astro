---
import '@/styles/global.css';
import FaviconHead from '@components/FaviconHead.astro';
import SeoHead from '@components/SeoHead.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import ElleaNavbar from '@components/ellea/ElleaNavbar.astro';
import ElleaFooter from '@components/ellea/ElleaFooter.astro';
import NewsletterSection from '@components/ellea/NewsletterSection.astro';
import type { BreadcrumbItem } from '@/lib/breadcrumb';
import { DEFAULT_ROBOTS } from '@/lib/seo';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  robots?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  ampUrl?: string;
  breadcrumbs?: BreadcrumbItem[] | null;
  showNav?: boolean;
  showBreadcrumb?: boolean;
  showFooter?: boolean;
  showNewsletter?: boolean;
}

const {
  title,
  description = '',
  lang = 'fr-CA',
  robots,
  image,
  imageAlt,
  type,
  ampUrl,
  breadcrumbs,
  showNav = true,
  showBreadcrumb = false,
  showFooter = true,
  showNewsletter = true,
} = Astro.props;

const renderBreadcrumb = showBreadcrumb && breadcrumbs && breadcrumbs.length > 0;
const robotsContent = robots ?? DEFAULT_ROBOTS;
---
<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..700;1,9..144,400..700&family=Instrument+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    {description && <meta name="description" content={description} />}
    <meta name="robots" content={robotsContent} />
    <title>{title}</title>
    <SeoHead title={title} description={description} image={image} imageAlt={imageAlt} type={type} />
    {ampUrl && <link rel="amphtml" href={ampUrl} />}
    <FaviconHead />
  </head>
  <body class="bg-bg font-sans text-ink antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-brand focus:px-4 focus:py-2 focus:text-white"
    >
      Aller au contenu principal
    </a>
    {showNav && <ElleaNavbar />}
    {renderBreadcrumb && <Breadcrumb items={breadcrumbs} />}
    <div id="main-content">
      <slot name="before-main" />
      <slot />
      {showNewsletter && <NewsletterSection />}
    </div>
    {showFooter && <ElleaFooter />}
  </body>
</html>
