---
import PageLayout from '@layouts/PageLayout.astro';
import JsonLd from '@components/JsonLd.astro';
import PostHero from '@components/post/PostHero.astro';
import PostBody from '@components/post/PostBody.astro';
import { breadcrumbTrails } from '@/lib/breadcrumb';
import { buildArticleGraph } from '@/lib/schema';
import { formatTitle } from '@/lib/seo';
import type { Post } from '@/data/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;

const origin = Astro.site ?? new URL(Astro.url.origin);
const path = `/blog/${post.slug}/`;
const ampUrl = new URL(`/blog/${post.slug}/amp/`, origin).href;
const articleGraph = buildArticleGraph(post, origin, { path, lang: 'fr-CA' });
---
<PageLayout
  title={formatTitle(post.title)}
  description={post.summary}
  image={post.image ? `${post.image}.webp` : undefined}
  imageAlt={post.imageAlt}
  type="article"
  ampUrl={ampUrl}
  breadcrumbs={breadcrumbTrails.post(post.title, 'fr')}
>
  <JsonLd schema={articleGraph} />
  <main>
    <PostHero post={post} />
    <PostBody post={post} />
  </main>
</PageLayout>
